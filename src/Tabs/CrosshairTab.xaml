<UserControl x:Class="DigitalScope.Tabs.CrosshairTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrl="clr-namespace:DigitalScope.Controls"
             mc:Ignorable="d"
             d:DesignWidth="820" d:DesignHeight="640">
    <Grid PreviewMouseDown="Tab_PreviewMouseDown">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,16,28,24">

            <TextBlock Style="{StaticResource H1}" Text="Crosshair Overlay"/>

            <!-- General -->
            <TextBlock Style="{StaticResource H2}" Text="General"/>
            <Border Style="{StaticResource SettingCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Enable Crosshair Overlay"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        <TextBlock Text="Show a crosshair at the center of the screen"
                                   Style="{StaticResource SubText}"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkEnabled" Grid.Column="1"
                              Style="{StaticResource ToggleSwitch}"
                              VerticalAlignment="Center"
                              Checked="ChkEnabled_Changed"
                              Unchecked="ChkEnabled_Changed"/>
                </Grid>
            </Border>

            <!-- Type -->
            <TextBlock Style="{StaticResource H2}" Text="Type"/>
            <Border Style="{StaticResource SettingCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Crosshair Style"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        <TextBlock Text="Choose the shape of the crosshair"
                                   Style="{StaticResource SubText}"/>
                    </StackPanel>
                    <ComboBox x:Name="CbType" Grid.Column="1"
                              Style="{StaticResource ModernComboBox}"
                              VerticalAlignment="Center"
                              SelectionChanged="CbType_SelectionChanged">
                        <ComboBoxItem Content="✛  Cross" Tag="Cross"/>
                        <ComboBoxItem Content="●  Dot"   Tag="Dot"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Appearance -->
            <TextBlock Style="{StaticResource H2}" Text="Appearance"/>
            <Border Style="{StaticResource SettingCard}">
                <StackPanel>

                    <!-- Color -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Color" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <Border x:Name="PrvColor" Grid.Column="1" Width="26" Height="26"
                                CornerRadius="4" Margin="4,0,0,0" Cursor="Hand"
                                HorizontalAlignment="Right"
                                MouseLeftButtonDown="PrvColor_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                    <!-- Opacity -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Opacity" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            <TextBlock Text="Transparency of the crosshair" Style="{StaticResource SubText}"/>
                        </StackPanel>
                        <Slider x:Name="SlOpacity" Grid.Column="1"
                                Minimum="10" Maximum="100" TickFrequency="5"
                                IsSnapToTickEnabled="True" Style="{StaticResource ModernSlider}"
                                ValueChanged="SlOpacity_ValueChanged"/>
                        <TextBlock x:Name="LblOpacity" Grid.Column="2" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="6,0,0,0"/>
                    </Grid>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                    <!-- Size -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Size (px)" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            <TextBlock Text="Arm length / radius of the crosshair" Style="{StaticResource SubText}"/>
                        </StackPanel>
                        <Slider x:Name="SlSize" Grid.Column="1"
                                Minimum="2" Maximum="120" TickFrequency="1"
                                IsSnapToTickEnabled="True" Style="{StaticResource ModernSlider}"
                                ValueChanged="SlSize_ValueChanged"/>
                        <TextBlock x:Name="LblSize" Grid.Column="2" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="6,0,0,0"/>
                    </Grid>

                    <Separator x:Name="ThicknessSeparator" Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                    <Grid x:Name="ThicknessRow" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Thickness (px)" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            <TextBlock Text="Width of the crosshair lines" Style="{StaticResource SubText}"/>
                        </StackPanel>
                        <Slider x:Name="SlThickness" Grid.Column="1"
                            Minimum="1" Maximum="8" TickFrequency="0.5"
                                IsSnapToTickEnabled="True" Style="{StaticResource ModernSlider}"
                                ValueChanged="SlThickness_ValueChanged"/>
                        <TextBlock x:Name="LblThickness" Grid.Column="2" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="6,0,0,0"/>
                    </Grid>

                    <Separator x:Name="GapSeparator" Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                    <!-- Gap (hidden for Dot) -->
                    <Grid x:Name="GapRow">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Center Gap (px)" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            <TextBlock Text="Empty space around the crosshair center" Style="{StaticResource SubText}"/>
                        </StackPanel>
                        <Slider x:Name="SlGap" Grid.Column="1"
                                Minimum="0" Maximum="40" TickFrequency="1"
                                IsSnapToTickEnabled="True" Style="{StaticResource ModernSlider}"
                                ValueChanged="SlGap_ValueChanged"/>
                        <TextBlock x:Name="LblGap" Grid.Column="2" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="6,0,0,0"/>
                    </Grid>

                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource H2}" Text="Preview"/>
            <Border Style="{StaticResource SettingCard}" Padding="16">
                <Grid Background="#FF111111" MinHeight="90">
                    <Canvas x:Name="PreviewCanvas"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Button x:Name="BtnReset"
                    Content="Reset to Defaults"
                    Style="{StaticResource ModernButton}"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0"
                    Click="BtnReset_Click"/>

        </StackPanel>
    </ScrollViewer>

    <Popup x:Name="ColorPickerPopup"
           StaysOpen="True"
           AllowsTransparency="True"
           PopupAnimation="Fade">
        <ctrl:ColorPickerControl x:Name="Picker"/>
    </Popup>
    </Grid>
</UserControl>
