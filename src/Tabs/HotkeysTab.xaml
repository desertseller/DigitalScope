<UserControl x:Class="DigitalScope.Tabs.HotkeysTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="820" d:DesignHeight="640">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,16,28,24">

            <TextBlock Style="{StaticResource H1}" Text="Keyboard &amp; Mouse Shortcuts"/>

            <TextBlock Style="{StaticResource H2}" Text="Hotkey Configuration"/>

            <TextBlock Style="{StaticResource SubText}" 
                       Text="Supports keyboard combinations and mouse buttons (LButton, RButton, MButton, XButton1, XButton2)"
                       Margin="0,0,0,12"/>

            <Border Style="{StaticResource SettingCard}">
                <StackPanel>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Toggle Magnifier" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            <TextBlock Text="Show or hide the magnifier overlay" Style="{StaticResource SubText}"/>
                        </StackPanel>
                        <TextBox x:Name="TbToggleHotkey" Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}"
                                 VerticalAlignment="Center"
                                 Margin="0,1,0,0"
                                 KeyDown="TbToggleHotkey_KeyDown"
                                 GotFocus="TbHotkey_GotFocus"/>
                    </Grid>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,4"/>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Toggle Crosshair" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            <TextBlock Text="Show or hide the crosshair overlay" Style="{StaticResource SubText}"/>
                        </StackPanel>
                        <TextBox x:Name="TbCrosshairHotkey" Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}"
                                 VerticalAlignment="Center"
                                 Margin="0,1,0,0"
                                 KeyDown="TbCrosshairHotkey_KeyDown"
                                 GotFocus="TbHotkey_GotFocus"/>
                    </Grid>

                </StackPanel>
            </Border>

            <TextBlock x:Name="LblStatus"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" Margin="0,8,0,0"
                       TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
